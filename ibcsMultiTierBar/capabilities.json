{
  "dataRoles": [
    { "displayName": "Category", "name": "category", "kind": "Grouping" },
    { "displayName": "Actual (AC)", "name": "actual", "kind": "Measure" },
    { "displayName": "Reference (PY / PL / BU / FC)", "name": "reference", "kind": "Measure" }
  ],
  "objects": {
    "general": {
      "properties": {
        "scenario": {
          "type": {
            "enumeration": [
              { "value": "PY", "displayName": "Previous Year (PY)" },
              { "value": "PL", "displayName": "Plan (PL)" },
              { "value": "BU", "displayName": "Budget (BU)" },
              { "value": "FC", "displayName": "Forecast (FC)" }
            ]
          }
        },
        "invert": { "type": { "bool": true } },
        "showAbsoluteTier": { "type": { "bool": true } },
        "showPercentTier": { "type": { "bool": true } },
        "decimals": { "type": { "numeric": true } },
        "axisWidthPercent": { "type": { "numeric": true } },
        "maxVisibleCategories": { "type": { "numeric": true } },
        "enableScrollbar": { "type": { "bool": true } },
        "minBandPx": { "type": { "numeric": true } }
      }
    },
    "colors": {
      "properties": {
        "positive": { "type": { "fill": { "solid": { "color": true } } } },
        "negative": { "type": { "fill": { "solid": { "color": true } } } },
        "zero": { "type": { "fill": { "solid": { "color": true } } } },
        "acFill": { "type": { "fill": { "solid": { "color": true } } } }
      }
    }
  },
  "dataViewMappings": [
    {
      "conditions": [
        { "category": { "max": 1 }, "actual": { "max": 1 }, "reference": { "max": 1 } }
      ],
      "categorical": {
        "categories": {
          "for": { "in": "category" },
          "dataReductionAlgorithm": { "top": { "count": 200 } }
        },
        "values": {
          "select": [
            { "bind": { "to": "actual" } },
            { "bind": { "to": "reference" } }
          ]
        }
      }
    }
  ],
  "privileges": []
}
