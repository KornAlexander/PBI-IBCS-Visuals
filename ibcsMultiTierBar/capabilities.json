{
  "dataRoles": [
    { "displayName": "Category", "name": "category", "kind": "Grouping" },
    { "displayName": "Actual (AC)", "name": "actual", "kind": "Measure" },
    { "displayName": "Reference (PY / PL / BU / FC)", "name": "reference", "kind": "Measure" }
  ],
  "objects": {
    "general": {
      "properties": {
        "scenario": {
          "type": {
            "enumeration": [
              { "value": "PY", "displayName": "Previous Year (PY)" },
              { "value": "PL", "displayName": "Plan (PL)" },
              { "value": "BU", "displayName": "Budget (BU)" },
              { "value": "FC", "displayName": "Forecast (FC)" }
            ]
          }
        },
        "invert": { "type": { "bool": true } },
        "showAbsoluteTier": { "type": { "bool": true } },
        "showPercentTier": { "type": { "bool": true } },
        "decimals": { "type": { "numeric": true } },
        "decimalsAbs": { "type": { "numeric": true } },
        "decimalsPct": { "type": { "numeric": true } },
        "axisWidthPercent": { "type": { "numeric": true } },
        "maxVisibleCategories": { "type": { "numeric": true } },
        "enableScrollbar": { "type": { "bool": true } },
        "sortBy": {
          "type": {
            "enumeration": [
              { "value": "category", "displayName": "Category" },
              { "value": "actual", "displayName": "Actual" },
              { "value": "reference", "displayName": "Reference" },
              { "value": "variance", "displayName": "Δ Absolute" },
              { "value": "variancePct", "displayName": "Δ Percent" }
            ]
          }
        },
        "sortDir": {
          "type": {
            "enumeration": [
              { "value": "asc", "displayName": "Ascending" },
              { "value": "desc", "displayName": "Descending" }
            ]
          }
        },
        "showFirstLastDelta": { "type": { "bool": true } },
        "showReferenceMarker": { "type": { "bool": true } },
        "topNEnabled": { "type": { "bool": true } },
        "topN": { "type": { "numeric": true } },
        "showOthers": { "type": { "bool": true } },
        "layoutMode": {
          "type": {
            "enumeration": [
              { "value": "auto", "displayName": "Auto (fit to canvas)" },
              { "value": "multi", "displayName": "Multi-tier (Δ + Δ%)" },
              { "value": "single", "displayName": "Single variance tier" },
              { "value": "inline", "displayName": "Inline variance" }
            ]
          }
        },
        "minBandPx": { "type": { "numeric": true } },
        "pctOutlierCutoff": { "type": { "numeric": true } },
        "absOutlierCutoff": { "type": { "numeric": true } }
      }
    },
    "colors": {
      "properties": {
        "positive": { "type": { "fill": { "solid": { "color": true } } } },
        "negative": { "type": { "fill": { "solid": { "color": true } } } },
        "zero": { "type": { "fill": { "solid": { "color": true } } } },
        "acFill": { "type": { "fill": { "solid": { "color": true } } } }
      }
    },
    "text": {
      "properties": {
        "fontFamily": { "type": { "formatting": { "fontFamily": true } } },
        "fontSize": { "type": { "formatting": { "fontSize": true } } },
        "bold": { "type": { "bool": true } },
        "italic": { "type": { "bool": true } },
        "underline": { "type": { "bool": true } },
        "color": { "type": { "fill": { "solid": { "color": true } } } }
      }
    },
    "about": {
      "properties": {
        "version": { "type": { "text": true } },
        "author": { "type": { "text": true } },
        "website": { "type": { "text": true } }
      }
    }
  },
  "dataViewMappings": [
    {
      "conditions": [
        { "category": { "max": 1 }, "actual": { "max": 1 }, "reference": { "max": 1 } }
      ],
      "categorical": {
        "categories": {
          "for": { "in": "category" },
          "dataReductionAlgorithm": { "top": { "count": 30000 } }
        },
        "values": {
          "select": [
            { "bind": { "to": "actual" } },
            { "bind": { "to": "reference" } }
          ]
        }
      }
    }
  ],
  "privileges": []
}
